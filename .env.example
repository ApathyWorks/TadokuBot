DISCORD_TOKEN=

# Optional: Discord role names (comma-separated) whose members may use the admin
# commands, in addition to anyone with the Manage Server permission. Matched
# case-insensitively. Example: ADMIN_ROLES=Moderator,Officers
ADMIN_ROLES=

# Optional: log in to tadoku.app so API calls carry a session (Ory Kratos). The
# session cookie expires; the bot re-logs-in and retries automatically on a
# 401/403. Leave blank to use the public endpoints anonymously (the default).
# Use a dedicated bot account WITHOUT 2FA (2FA blocks automated login).
#   KRATOS_PUBLIC_URL defaults to https://account.tadoku.app/kratos.
TADOKU_EMAIL=
TADOKU_PASSWORD=
KRATOS_PUBLIC_URL=

# Optional: poster/cover images on the log-feed card. When a log is tagged with a
# media type, the card shows the material's cover on the right. Each source is
# independent -- leave a key blank to disable that source (games via VNDB need no
# key). Missing keys / lookups just fall back to the poster-less card.
#   MAL_CLIENT_ID       anime & manga covers (MyAnimeList API v2). Register an app
#                       at https://myanimelist.net/apiconfig to get a Client ID.
#   GOOGLE_BOOKS_API_KEY  book covers (Google Books). The keyless quota is shared
#                       and rate-limited, so a key is needed for reliable lookups.
MAL_CLIENT_ID=
GOOGLE_BOOKS_API_KEY=
